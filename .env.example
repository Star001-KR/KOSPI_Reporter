APP_NAME=Kospi Portfolio Research API
DATABASE_URL=sqlite:///./data/kospi.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://127.0.0.1:5173

# Future collector keys
OPENDART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AI news summary — runs against the local `claude` CLI using your Claude
# subscription (OAuth). Make sure `claude login` has been completed on the
# machine running the API server; without the CLI on PATH the feature
# degrades to the rule-based article description.
# Override CLAUDE_CLI_PATH if `claude` is installed somewhere non-standard.
CLAUDE_CLI_PATH=claude
AI_SUMMARY_MODEL=claude-haiku-4-5-20251001
# How many of the newest articles per symbol to summarize at collection time.
AI_SUMMARY_EAGER_PER_SYMBOL=3

# Google OAuth social login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_DAYS=30
# Comma-separated allowlist of Google emails permitted to sign in. Empty means
# anyone with a Google account can sign in (local-dev default). Set this to your
# trusted users before exposing the app publicly.
AUTH_ALLOWED_EMAILS=

# Development-only routes (/api/dev/* seed + mock helpers). Keep false in production.
ENABLE_DEV_ROUTES=true

# Web
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
