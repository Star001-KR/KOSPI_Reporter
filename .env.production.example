# Production environment for the KOSPI Reporter API.
# Copy to .env on the API host, or set these as platform environment variables.

APP_NAME=KOSPI Reporter API

# SQLite on a persistent volume mounted at /app/data (see docs/deployment.md).
# For a managed database, set a full DATABASE_URL and add its driver to
# apps/api/requirements.txt (for example psycopg2-binary for PostgreSQL).
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/kospi

# Comma-separated allowed web origins — set to the real web domain (no wildcard).
CORS_ORIGINS=https://your-domain.example

# The web origin users land on; OAuth redirects back here after sign-in.
FRONTEND_URL=https://your-domain.example

# Google OAuth social login — required for sign-in on a public deployment.
# Register the redirect URI below in the Google Cloud console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.your-domain.example/api/auth/google/callback

# Session cookies must be Secure over HTTPS.
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_DAYS=30

# Comma-separated allowlist of Google emails permitted to sign in. REQUIRED for a
# limited-audience deployment — without it, anyone with a Google account can sign
# in. Example: alice@example.com,bob@example.com
AUTH_ALLOWED_EMAILS=

# Collector API keys.
OPENDART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Scheduler interval in seconds (worker process).
COLLECTION_INTERVAL_SECONDS=900

# Development-only routes (/api/dev/*) must stay disabled in production.
ENABLE_DEV_ROUTES=false

# The web build needs the public API URL at build time:
#   VITE_API_BASE_URL=https://api.your-domain.example npm run web:build
